{
    "$schema": "https://apify.com/schemas/v1/input.ide.json",
    "title": "Edutu Scholarship Scraper",
    "description": "Scrapes scholarship opportunities from multiple sources",
    "type": "object",
    "schemaVersion": 1,
    "properties": {
        "startUrls": {
            "title": "Start URLs",
            "type": "array",
            "description": "URLs to scrape scholarships from",
            "editor": "requestListSources",
            "prefill": [
                { "url": "https://opportunitiescircle.com/explore-opportunities" },
                { "url": "https://globalscholardesk.com/category/scholarships/" },
                { "url": "https://www.internationalscholarships.com/scholarships" },
                { "url": "https://jobs.smartyacad.com/category/scholarship/" },
                { "url": "https://jobs.smartyacad.com/category/grants/" }
            ]
        },
        "maxResults": {
            "title": "Max Results",
            "type": "integer",
            "description": "Maximum number of scholarships to scrape per site",
            "default": 20,
            "minimum": 1,
            "maximum": 100
        },
        "proxyConfiguration": {
            "title": "Proxy Configuration",
            "type": "object",
            "description": "Use Apify Proxy to avoid blocking",
            "editor": "proxy",
            "default": { "useApifyProxy": true }
        },
        "backendUrl": {
            "title": "Backend API URL",
            "type": "string",
            "description": "Your backend API URL to auto-save scraped data",
            "editor": "textfield",
            "default": "http://localhost:3001/opportunities/bulk-import"
        },
        "backendApiKey": {
            "title": "Backend API Key",
            "type": "string",
            "description": "API key for authenticating with your backend (optional)",
            "editor": "textfield",
            "isSecret": true
        },
        "autoSaveToBackend": {
            "title": "Auto Save to Backend",
            "type": "boolean",
            "description": "Automatically send scraped data to your backend",
            "editor": "checkbox",
            "default": true
        }
    },
    "required": ["startUrls"]
}
