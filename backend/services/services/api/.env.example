NODE_ENV=production
PORT=3000

# Public app origins used by CORS and callback links.
FRONTEND_URL=https://app.edutu.ai
ADMIN_URL=https://admin.edutu.ai
MOBILE_APP_URL=https://app.edutu.ai

# Database / Supabase.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DIRECT_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Auth.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your-clerk-publishable-key
CLERK_SECRET_KEY=your-clerk-secret-key

# AI enrichment.
DEEPSEEK_API_KEY=your-deepseek-api-key
AI_KEY_ENCRYPTION_SECRET=replace-with-a-long-random-secret
OPENROUTER_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# Scraper / opportunity processing.
SERPER_API_KEY=
APIFY_WEBHOOK_API_KEY=
SCRAPER_SCHEDULER_ENABLED=true
OPPORTUNITY_VERIFICATION_ENABLED=false

# Share-card generation.
# Generated during scraping/backfills and reused by mobile users.
OPPORTUNITY_SHARE_CARD_GENERATION=true
OPPORTUNITY_SHARE_CARD_BUCKET=opportunity-share-cards
OPPORTUNITY_SHARE_CARD_CONCURRENCY=2

# Optional production integrations.
PAYSTACK_SECRET_KEY=
BILLING_PUBLIC_URL=https://app.edutu.ai
EDUTU_API_KEYS=
