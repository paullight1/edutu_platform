# Server Configuration
PORT=3000
NODE_ENV=development

# Database (Supabase Connection Pooler)
DATABASE_URL="postgresql://postgres:password@aws-1-eu-west-1.pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres:password@aws-1-eu-west-1.pooler.supabase.com:5432/postgres"

# Supabase API
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Clerk Authentication
CLERK_SECRET_KEY="sk_test_your-clerk-secret-key"

# Google Gemini AI
GEMINI_API_KEY="your-gemini-api-key"

# Serper Search API
SERPER_API_KEY="your-serper-api-key"

# Admin Emails (comma-separated)
ADMIN_EMAILS="admin@edutu.com"

# Apify Webhook API Key
APIFY_WEBHOOK_API_KEY="your-webhook-api-key"
