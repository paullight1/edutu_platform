# Supabase configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public API/runtime settings
PORT=3000
NODE_ENV=development
CORS_ORIGINS=https://admin.edutu.org

# Scholarship Engine public documentation settings
EDUTU_API_PUBLIC_URL=https://api.edutu.org/v1
EDUTU_API_OPENAPI_URL=https://api.edutu.org/v1/openapi.json
EDUTU_DOCS_URL=https://docs.edutu.org
EDUTU_DASHBOARD_URL=https://www.edutu.org/developers
EDUTU_MARKETING_URL=https://www.edutu.org/scholarship-engine

# Auth and billing
CLERK_SECRET_KEY=your-clerk-secret-key
PAYSTACK_SECRET_KEY=your-paystack-secret-key
PAYSTACK_PLAN_MONTHLY=pln_monthly_code
PAYSTACK_PLAN_YEARLY=pln_yearly_code

# AI providers
GEMINI_API_KEY=your-gemini-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
