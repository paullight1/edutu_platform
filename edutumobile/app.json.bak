{
  "expo": {
    "name": "Edutu",
    "slug": "edutu",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "edutu",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#171a4f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.edutu.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#171a4f"
      },
      "package": "com.edutu.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-router",
        {
          "origin": "https://edutu.org"
        }
      ]
    ],
    "experiments": {
      "tsconfigPaths": true
    }
  }
}