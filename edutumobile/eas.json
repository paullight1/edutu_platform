{
  "cli": {
    "version": ">= 13.3.0",
    "appVersionSource": "local"
  },
  "build": {
        "development": {
            "environment": "development",
            "developmentClient": true,
            "distribution": "internal",
            "channel": "development",
            "ios": {
                "simulator": true
            }
        },
        "development:device": {
            "environment": "development",
            "developmentClient": true,
            "distribution": "internal",
            "channel": "development"
        },
        "preview": {
            "environment": "preview",
            "distribution": "internal",
            "channel": "preview",
            "ios": {
                "simulator": true
            }
        },
        "preview:device": {
            "environment": "preview",
            "distribution": "internal",
            "channel": "preview"
        },
    "production": {
      "environment": "production",
      "channel": "production",
      "android": {
        "buildType": "app-bundle"
      }
    },
    "apk": {
      "environment": "preview",
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      }
    }
  },
    "submit": {
        "production": {}
    }
}
