# Clerk Authentication (shared with mobile app)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_or_live_xxx

# Absolute login lifetime in hours. After this many hours signed in (regardless
# of activity), the user is signed out and must re-authenticate. Default: 24.
# Keep this aligned with the session token lifetime set in the Clerk Dashboard.
VITE_SESSION_ABSOLUTE_HOURS=24

# Native Google One Tap prompt for unauthenticated visitors. Renders Google's
# own One Tap UI via Clerk. Requires "Google" + One Tap enabled in the Clerk
# Dashboard; set to "false" to hide it. Default: enabled.
VITE_GOOGLE_ONE_TAP=true

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Backend API used by billing, roadmap, AI, admin, and protected app workflows
VITE_API_URL=https://edutu-api.onrender.com
VITE_BACKEND_URL=https://edutu-api.onrender.com

# Separate admin portal. The user web app redirects /admin/* here instead of bundling admin code.
VITE_ADMIN_URL=https://admin.edutu.org

# Dedicated docs site for Scholarship Engine.
VITE_DOCS_URL=https://docs.edutu.org
VITE_API_OPENAPI_URL=https://api.edutu.org/v1/openapi.json

# Next.js marketing site (edutu-web). When set, the public marketing routes
# (/scholarship-api, /scholarship-engine, /developers) redirect here so there
# is one marketing surface. Leave empty until the Next site is deployed.
VITE_MARKETING_URL=

# Public SEO/share canonical URL. Use the exact production domain verified in Google Search Console.
VITE_PUBLIC_SITE_URL=https://www.edutu.org

# Optional Search Console meta verification token. DNS verification is still preferred for production.
VITE_GOOGLE_SITE_VERIFICATION=

# Optional monitoring
VITE_SENTRY_DSN=
VITE_APP_VERSION=

# Optional admin allow-list. Prefer server-side roles/Clerk metadata for production.
VITE_ADMIN_EMAILS=admin@edutu.org

# Optional n8n integration. Do not put private webhook/API secrets in VITE_* values.
VITE_N8N_WEBHOOK_URL=
