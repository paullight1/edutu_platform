# Clerk Authentication (shared with mobile app)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your-key

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Backend API used by billing, roadmap, AI, and protected app workflows
VITE_API_URL=https://your-api.example.com

# Optional monitoring
VITE_SENTRY_DSN=
VITE_APP_VERSION=

# Optional admin allow-list. Prefer server-side roles/Clerk metadata for production.
VITE_ADMIN_EMAILS=

# Optional n8n integration. Do not put private webhook/API secrets in VITE_* values.
VITE_N8N_WEBHOOK_URL=
