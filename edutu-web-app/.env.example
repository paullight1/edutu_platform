# Clerk Authentication (shared with mobile app)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_or_live_xxx

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Backend API used by billing, roadmap, AI, admin, and protected app workflows
VITE_API_URL=https://edutu-api.onrender.com
VITE_BACKEND_URL=https://edutu-api.onrender.com

# Separate admin portal. The user web app redirects /admin/* here instead of bundling admin code.
VITE_ADMIN_URL=https://admin.edutu.org

# Optional monitoring
VITE_SENTRY_DSN=
VITE_APP_VERSION=

# Optional admin allow-list. Prefer server-side roles/Clerk metadata for production.
VITE_ADMIN_EMAILS=admin@edutu.ai

# Optional n8n integration. Do not put private webhook/API secrets in VITE_* values.
VITE_N8N_WEBHOOK_URL=
